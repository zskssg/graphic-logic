{
  "name": "graphic-logic",
  "version": "1.0.2",
  "description": "A TypeScript library for graphical logic exploration and learning",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "typescript",
    "graphics",
    "logic",
    "geometry",
    "learning",
    "library"
  ],
  "author": "zsk6",
  "license": "LGPL-3.0-only",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zskssg/graphic-logic.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "config": {
    "registry": "https://registry.npmmirror.com/"
  }
}
